<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/awam_main"
    android:padding="20dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Database Entitas"
            android:textColor="@color/awam_surface"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true">

            <TextView
                android:id="@+id/btnToggleList"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Daftar"
                android:textColor="@color/awam_surface"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:textSize="12sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_filter_chip" />

            <TextView
                android:id="@+id/btnToggleGraph"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Grafik"
                android:textColor="@color/awam_surface"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:textSize="12sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_filter_chip" />
        </LinearLayout>
    </RelativeLayout>

    <EditText
        android:id="@+id/etSearchDatabase"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/awam_card_bg"
        android:paddingHorizontal="16dp"
        android:hint="Cari nomor, URL, atau rekening..."
        android:textColorHint="@color/awam_text_light"
        android:textColor="@color/awam_surface"
        android:drawableStart="@android:drawable/ic_menu_search"
        android:drawablePadding="8dp"
        android:drawableTint="@color/awam_text_light"
        android:inputType="text"
        android:maxLines="1"
        android:layout_marginBottom="12dp" />

    <HorizontalScrollView
        android:id="@+id/svFilterGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:id="@+id/llFilterGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnFilterAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Semua"
                android:textColor="@color/awam_surface"
                android:background="@drawable/bg_filter_chip"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/btnFilterPhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phone"
                android:textColor="@color/awam_surface"
                android:background="@drawable/bg_filter_chip"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/btnFilterBank"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bank"
                android:textColor="@color/awam_surface"
                android:background="@drawable/bg_filter_chip"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/btnFilterUrl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="URL"
                android:textColor="@color/awam_surface"
                android:background="@drawable/bg_filter_chip"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/btnFilterEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email"
                android:textColor="@color/awam_surface"
                android:background="@drawable/bg_filter_chip"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:clickable="true"
                android:focusable="true"
                android:textSize="12sp" />

        </LinearLayout>
    </HorizontalScrollView>

    <ProgressBar
        android:id="@+id/pbDatabaseLoading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="8dp"
        android:visibility="gone" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvDatabase"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="80dp" />

        <WebView
            android:id="@+id/wvGraph"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:layout_marginBottom="80dp" />
    </FrameLayout>

</LinearLayout>
