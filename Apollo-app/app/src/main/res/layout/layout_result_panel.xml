<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Area kosong setengah atas untuk klik keluar (Outside Touch) -->
    <View
        android:id="@+id/outsideTouchArea"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000" />

    <!-- Panel hasil di setengah bawah layar -->
    <LinearLayout
        android:id="@+id/panelContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_result_panel"
        android:orientation="vertical"
        android:paddingBottom="24dp"
        android:clickable="true"
        android:focusable="true">

        <!-- Header Bar -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingHorizontal="20dp">

            <!-- Tombol Tutup (HANYA IKON SILANG TANPA TEKS) -->
            <ImageButton
                android:id="@+id/btnClose"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_close"
                android:contentDescription="Tutup" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:text="@string/awam_scan_header"
                android:textColor="@color/awam_surface"
                android:textSize="18sp"
                android:textStyle="bold" />

        </RelativeLayout>

        <!-- Risk Bar -->
        <FrameLayout
            android:id="@+id/riskBarLayout"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_risk_bar_red"
            android:paddingHorizontal="20dp">

            <TextView
                android:id="@+id/tvRiskLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical|start"
                android:text="BAHAYA"
                android:textColor="@color/awam_surface"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvRiskScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical|end"
                android:text="87%"
                android:textColor="@color/awam_surface"
                android:textSize="20sp"
                android:textStyle="bold" />

        </FrameLayout>

        <!-- Category / Target Section -->
        <LinearLayout
            android:id="@+id/targetSectionLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_source_card"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">

            <!-- Left: Target text -->
            <TextView
                android:id="@+id/tvTargetValue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/awam_surface"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- Right: SCAM badge -->
            <TextView
                android:id="@+id/tvScamBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_risk_bar_red"
                android:text="SCAM"
                android:textColor="@color/awam_surface"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp" />

        </LinearLayout>

        <!-- Penjelasan AI -->
        <TextView
            android:id="@+id/tvExplanation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="16dp"
            android:lineSpacingExtra="4dp"
            android:text="Domain jnt-express-id.xyz baru didaftarkan 4 hari lalu dan bukan domain resmi J&amp;T Express (jet.co.id). Nomor 08123456789 ditemukan dalam 2 laporan penipuan online."
            android:textColor="@color/awam_surface"
            android:textSize="14sp" />

        <!-- Daftar Sumber (Card) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_source_card"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="@string/sources_header"
                android:textColor="@color/awam_text_light"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/sourcesListContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>

        <!-- Tombol Aksi -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- Tombol Bagikan -->
            <Button
                android:id="@+id/btnShare"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_button_primary"
                android:text="@string/btn_share"
                android:textAllCaps="false"
                android:textColor="@color/awam_surface"
                android:textSize="15sp"
                android:textStyle="bold"
                android:drawableStart="@drawable/ic_share"
                android:paddingHorizontal="24dp"
                android:drawablePadding="8dp" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
