<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@color/awam_card_bg"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp"
    android:layout_marginBottom="8dp"
    android:gravity="center_vertical">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvEntityValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="08123456789"
            android:textColor="@color/awam_surface"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvEntityCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Penipuan Online"
            android:textColor="@color/awam_danger"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvEntityType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@color/awam_main"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:text="PHONE"
        android:textColor="@color/awam_text_light"
        android:textSize="10sp"
        android:textStyle="bold" />

</LinearLayout>
